---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
	index?: number;
}

const { data, id } = Astro.props.project;
const index = Astro.props.index ?? 0;

const imgBgColors = ['#e8eaf6', '#fce4ec', '#e8f5e9', '#fff8e1'];
const imgBg = imgBgColors[index % imgBgColors.length];

const year = new Date(data.publishDate).getFullYear();
---

<a class="project-row" href={`/work/${id}`}>
	<div class="project-info">
		<h3 class="title">{data.title}</h3>
		<hr class="divider" />
		<div class="meta">
			{data.tags && <span class="tags">{data.tags[0].toUpperCase()}</span>}
			<span class="year">{year}</span>
		</div>
	</div>
	<div class="project-image">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
	</div>
</a>

<style>
	.project-row {
		display: grid;
		grid-template-columns: 1fr 2fr;
		align-items: center;
		gap: 2rem;
		text-decoration: none;
		padding-block: 3rem;
		border-top: 1px solid #e0e0e0;
		transition: opacity 0.2s ease;
	}

	.project-row:hover .title,
	.project-row:hover .tags,
	.project-row:hover .year {
		color: #7611a6;
	}

	.project-row:hover .divider {
		border-top-color: #7611a6;
	}

	.project-info {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-inline: 1rem;
	}

	.title {
		font-size: var(--text-2xl);
		font-weight: 700;
		color: #0a0a14;
		line-height: 1.2;
		transition: color 0.2s ease;
	}

	.divider {
		border: none;
		border-top: 2px solid #ccc;
		width: 2.5rem;
		margin: 0;
		transition: border-top-color 0.2s ease;
	}

	.meta {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.tags {
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.08em;
		color: #333;
		transition: color 0.2s ease;
	}

	.year {
		font-size: var(--text-sm);
		color: #999;
		transition: color 0.2s ease;
	}

	.project-image {
		border-radius: 1rem;
		overflow: hidden;
		height: 360px;
		will-change: transform;
	}

	.project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		display: block;
		transition: transform 0.4s ease;
	}

	.project-row:hover .project-image img {
		transform: scale(1.06);
	}

	@media (max-width: 50em) {
		.project-row {
			grid-template-columns: 1fr;
		}

		.project-image img {
			max-height: 220px;
		}
	}
</style>
